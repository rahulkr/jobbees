{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "NestJS API",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  }
}
