// JOBBees — Database schema
//
// This is the source of truth for the data model.
//
// Conventions (see PROJECT_CONTEXT.md §9):
// - cuid2 IDs (set in app code via @paralleldrive/cuid2, NOT cuid() default)
// - Money in cents (Int), never Decimal/Float
// - UTC in DB, Australia/Sydney in UI
// - Soft delete on user-facing entities (deletedAt)
// - Foreign key indexes are manual — Prisma does NOT auto-add them
// - All amounts/compliance tables have countryCode (multi-country ready, AU-only at MVP)
//
// pgvector setup:
//   Add a manual migration with: CREATE EXTENSION IF NOT EXISTS vector;
//   Vector columns use Unsupported("vector(1536)"), queried via $queryRaw.
//   HNSW indexes added in raw SQL migrations.

generator client {
  provider        = "prisma-client-js"
  output          = "./generated"
  // Driver adapters are required by the Prisma 7 pattern we use: PrismaClient
  // receives a PrismaPg adapter constructed from process.env.DATABASE_URL,
  // instead of the legacy `datasource db { url = env(...) }` line that no
  // longer exists in v7. Adapters are still gated behind a preview flag at
  // schema-generation time — once they go GA we can drop this line.
  // See packages/prisma/seed.ts and (later) apps/api/src/.../prisma.service.ts
  // for the consumers.
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  // Connection URL lives in prisma.config.ts (Prisma 7 pattern). The migrate
  // engine reads DATABASE_URL from env via the config file. Application code
  // instantiates PrismaClient with a driver adapter (PrismaPg) — see
  // apps/api/src/.../prisma.service.ts when it lands in Sprint 1.
  //
  // Note: pgvector extension is created via the raw migration
  // 000_enable_pgvector/migration.sql. Vector columns use
  // Unsupported("vector(1536)") below, and we query them via
  // prisma.$queryRaw with the <=> cosine distance operator.
  // See .claude/skills/pgvector-match/SKILL.md for the query pattern.
}

// =============================================================================
// ENUMS
// =============================================================================

// Terminology note: this project uses the original JOBBees RN app's vocabulary
// (Job / Client / Offer / Tasker) to avoid trademark overlap with Airtasker
// (Task / Poster / Bid). Schema, code, and UI all use the JOBBees terms.
// "Tasker" is kept because the original RN app used it too; it is a common
// English word, and standalone (not paired with "Task") it is defensible.

enum UserRole {
  CLIENT       // the person posting a job (old name: POSTER)
  TASKER       // the person doing the job
  ADMIN
  SUPER_ADMIN
}

enum CategoryType {
  TRANSACTIONAL // payment flows through platform (default; only type at MVP)
  LEAD          // client→tasker intro, payment off-platform (post-MVP)
}

enum JobStatus {
  DRAFT
  PUBLISHED
  OFFERING      // accepting offers (old: BIDDING)
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum OfferStatus {
  ACTIVE
  WITHDRAWN
  ACCEPTED
  DECLINED
  EXPIRED
}

enum PaymentState {
  AUTHORISED
  CAPTURED
  RE_AUTH_REQUIRED  // authorised but approaching 7d expiry
  SETUP_ONLY        // SetupIntent only, no charge yet
  FAILED
  VOIDED
  REFUNDED
  PARTIAL_REFUNDED
}

enum DisputeState {
  OPEN
  TIER0_PROPOSED
  ACCEPTED
  ESCALATED
  RESOLVED
  CLOSED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
  MANUAL_REVIEW
}

enum ConnectStatus {
  NOT_STARTED
  PENDING
  COMPLETE
  RESTRICTED
}

// =============================================================================
// COUNTRY (multi-country ready — see ADR 003)
// =============================================================================

model Country {
  code          String   @id  // ISO 3166-1 alpha-2: "AU", "NZ"
  name          String
  currencyCode  String   // "AUD", "NZD"
  defaultLocale String   // "en-AU"
  taxModel      String   // "AU_GST_RCTI_ATO", "NZ_GST"
  phonePrefix   String   // "+61"
  isActive      Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users     User[]
  jobs      Job[]
}

// =============================================================================
// USERS
// =============================================================================

model User {
  id              String     @id // cuid2, set in app code
  email           String     @unique
  phone           String?    @unique
  firstName       String
  lastName        String
  role            UserRole
  passwordHash    String?    // null for social-only users

  emailVerified   Boolean    @default(false)
  phoneVerified   Boolean    @default(false)

  countryCode     String     @default("AU")
  country         Country    @relation(fields: [countryCode], references: [code])

  kycStatus       KycStatus  @default(NOT_STARTED)
  connectStatus   ConnectStatus @default(NOT_STARTED)

  // Profile fields (client + tasker)
  avatarUrl       String?
  defaultAddress  String?

  // Tasker-only fields (null for clients)
  bio             String?    @db.Text
  hourlyRateCents Int?
  abn             String?    // 11-digit Australian Business Number
  abnVerifiedAt   DateTime?
  abrBusinessName String?    // entity/business name from the ABR lookup
  noAbnReason     String?    // set when a tasker declares they have no ABN (RCTI path)

  // Tasker embedding for matching — pgvector column added via raw migration
  // bio + skills + recent jobs → 1536-dim embedding via OpenAI text-embedding-3-small
  embedding       Unsupported("vector(1536)")?

  // Suspension / ban (admin-triggered). Queryable flag — sessions are revoked
  // on suspend and login is blocked while set.
  suspendedAt      DateTime?
  suspensionReason String?

  deletedAt       DateTime?
  anonymisedAt    DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  postedJobs      Job[]      @relation("ClientJobs")
  offers          Offer[]
  reviewsGiven    Review[]   @relation("ReviewerReviews")
  reviewsReceived Review[]   @relation("RevieweeReviews")
  skills          UserSkill[]
  jobQuestions    JobQuestion[] @relation("AskerQuestions")
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  @@index([countryCode])
  @@index([role])
  @@index([deletedAt])
  @@index([suspendedAt])
  @@index([kycStatus])
  @@index([connectStatus])
}

model UserSkill {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     String   // free text tag for MVP
  createdAt DateTime @default(now())

  @@id([userId, skill])
  @@index([userId])
  @@index([skill])
}

// =============================================================================
// AUTH TOKENS (Sprint 1)
// =============================================================================
// Store token *hashes* only — never the raw token. Refresh tokens rotate on
// use: the consumed row gets revokedAt set and replacedById points at the new
// token's id (a rotation chain we can walk to detect refresh-token reuse).
// Email-verification + password-reset tokens are single-use (usedAt). All three
// are ephemeral — hard delete, no soft-delete (see PROJECT_CONTEXT.md §9).

model RefreshToken {
  id           String    @id // cuid2, set in app code
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique // SHA-256 of the opaque refresh token
  issuedAt     DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?   // id of the token that superseded this one (rotation chain)
  userAgent    String?
  ipAddress    String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model EmailVerificationToken {
  id        String    @id // cuid2
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id // cuid2
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// =============================================================================
// CATEGORIES
// =============================================================================

model Category {
  id            String       @id // cuid2
  slug          String       @unique
  name          String
  parentId      String?
  parent        Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children      Category[]   @relation("CategoryHierarchy")

  type          CategoryType @default(TRANSACTIONAL)
  leadFeeCents  Int?         // only used if type = LEAD (post-MVP)

  commissionRateBp Int       @default(1500) // basis points; 1500 = 15.00%
  isActive      Boolean      @default(true)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  jobs          Job[]

  @@index([parentId])
  @@index([isActive])
}

// =============================================================================
// JOBS  (old name in pre-rename schema: Task)
// =============================================================================

model Job {
  id              String       @id // cuid2
  clientId        String
  client          User         @relation("ClientJobs", fields: [clientId], references: [id], onDelete: Restrict)
  categoryId      String
  category        Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  title           String
  description     String       @db.Text

  countryCode     String       @default("AU")
  country         Country      @relation(fields: [countryCode], references: [code])

  // Snapshot from Category.type at creation; immutable per job
  transactionType CategoryType

  budgetCents     Int
  // platformFeeCents calculated on Payment, not stored here

  // Location
  addressLine     String?
  suburb          String?
  postcode        String?
  latitude        Float?
  longitude       Float?

  scheduledAt     DateTime?
  durationHours   Int?
  status          JobStatus    @default(DRAFT)

  // Vector embedding for matching — pgvector via raw migration
  embedding       Unsupported("vector(1536)")?
  embeddingHash   String?      // content hash for cache validation

  // Photos stored separately in JobPhoto
  // AI extraction metadata
  extractedFields Json?        // client's raw input vs structured AI extraction

  publishedAt     DateTime?
  acceptedAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  deletedAt       DateTime?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  offers          Offer[]
  photos          JobPhoto[]
  questions       JobQuestion[]

  @@index([clientId])
  @@index([categoryId])
  @@index([countryCode])
  @@index([status])
  @@index([scheduledAt])
  @@index([deletedAt])
  @@index([publishedAt])
}

model JobPhoto {
  id          String   @id // cuid2
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  blobUrl     String
  altText     String?
  width       Int?
  height      Int?
  exifJson    Json?     // EXIF metadata for tampering checks (post-MVP)
  moderation  String?   // "approved", "flagged", "rejected"
  createdAt   DateTime @default(now())

  @@index([jobId])
}

// Public Q&A under job — replaces counter-offer negotiation
model JobQuestion {
  id        String   @id // cuid2
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  askedById String   // a tasker
  asker     User     @relation("AskerQuestions", fields: [askedById], references: [id], onDelete: Restrict)
  question  String   @db.Text
  answer    String?  @db.Text  // client's answer
  answeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([askedById])
}

// =============================================================================
// OFFERS  (old name in pre-rename schema: Bid)
// =============================================================================

model Offer {
  id            String      @id // cuid2
  jobId         String
  job           Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  taskerId      String
  tasker        User        @relation(fields: [taskerId], references: [id], onDelete: Restrict)

  amountCents   Int
  message       String?     @db.Text
  estimatedAt   DateTime?   // when the tasker could start
  status        OfferStatus @default(ACTIVE)

  expiresAt     DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([jobId, taskerId]) // one active offer per job per tasker
  @@index([jobId])
  @@index([taskerId])
  @@index([status])
  @@index([expiresAt])
}

// =============================================================================
// REVIEWS
// =============================================================================

model Review {
  id            String   @id // cuid2
  jobId         String   // old: taskId
  reviewerId    String
  reviewer      User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Restrict)
  revieweeId    String
  reviewee      User     @relation("RevieweeReviews", fields: [revieweeId], references: [id], onDelete: Restrict)

  rating        Int      // 1-5
  text          String?  @db.Text
  response      String?  @db.Text // one-time response from reviewee

  // Blind review with timeout-reveal
  visibleAt     DateTime? // both reviews visible after both submitted OR after 14d

  deletedAt     DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([jobId, reviewerId])
  @@index([jobId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([deletedAt])
}

// =============================================================================
// AUDIT LOG (append-only)
// =============================================================================

model AuditLog {
  id            String   @id // cuid2
  actorId       String?
  action        String   // "user.suspend", "payment.refund", "dispute.resolve", etc.
  resourceType  String   // "User", "Job", "Payment", "Dispute"
  resourceId    String
  diffJson      Json?
  ipAddress     String?
  userAgent     String?

  createdAt     DateTime @default(now())

  @@index([resourceType, resourceId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

// =============================================================================
// FUTURE MODELS (add as features are built)
// =============================================================================
//
// Stripe payment: Payment, PaymentEvent (state transitions)
// Tax: TaxInvoice, Rcti, RctiAgreement, AtoExport
// Cancellation: Cancellation (with reason, fee, initiator)
// Dispute: Dispute (with state machine), DisputeEvidence, Tier0Proposal, AdminCaseBrief
// Notifications: NotificationPreference, NotificationLog, UnsubscribeToken
// Trust: ContentModerationResult, RateLimitBucket
// Privacy: ConsentRecord, DsrRequest, DsrAction
// Messaging: Thread, Message, ReadReceipt
// Promo: PromoCode, PromoCodeUsage
// Tasker profile: ServiceArea (suburb + radius OR postal-code list per tasker)
// Tasker profile: Portfolio (previous work photos, optional)
// Tasker verification: License (per-category professional license — manual admin review;
//   replaces an identity-vendor KYC model per ADR 005). Fields: userId, categoryId,
//   licenseType, licenseNumber, issuingState, expiresAt, uploadedBlobUrl,
//   status enum {PENDING, APPROVED, REJECTED, EXPIRED}, reviewerId, reviewerNotes,
//   reviewedAt, createdAt. Unique on (userId, categoryId). Indexes on userId,
//   categoryId, status, expiresAt.
//   licenseType is constrained to slugs in packages/types/src/licenses.ts
//   ALLOWED_LICENSE_TYPES (NOT a Prisma enum — kept as a TypeScript constant so we can
//   add new license types without a schema migration). Backend validates on every
//   insert/update; rejects unknown slugs with 400 INVALID_LICENSE_TYPE. Per ADR 005:
//   13 slugs total across 8 categories at MVP.
//   issuingState is constrained to ISSUING_STATES const in the same file (8 AU states).
// Category.requiresLicense Boolean @default(false) — flips bid-time guard on.
//   Seed `electrical`, `plumbing`, `gasfitting`, `asbestos`, `refrigerated_ac`,
//   `pest_control` as `true`.
// Category.licenseRequiredOverCents Int? — conditional licensing (license required
//   only when task value >= threshold). At MVP only `builder` uses this, set to
//   500000 cents ($5,000 AUD) per NSW Fair Trading Home Building Act 1989.
//   Other AU states have different thresholds — POST-MVP moves to per-state lookup.
//   Invariant: do NOT set both requiresLicense=true AND licenseRequiredOverCents.
//   Offer guard (row 532): hourly offers on a conditional category always require
//   the license; fixed-price offers require it only when offer.totalCents >= threshold.
// Tasker profile: Certification (non-license certs upload, optional — POST-MVP)
// Admin auth: AdminTotp (mandatory TOTP secret per admin — admin 2FA is IN)
// User state: User.suspendedAt / User.suspensionReason fields (or Suspension model
//   with history) — currently tracked via AuditLog actions, will need queryable flag
// Address book: SavedAddress (poster's saved addresses, currently single
//   `defaultAddress` field only)
// Q&A history: TaskQuestion already exists for ask/answer; no separate model needed
// Sessions: RefreshToken / Session (server-side session revoke, "logout from all
//   devices" — currently planned via JWT denylist in Redis but may need a model)
// SEO: TaskSeo (auto-generated slug/meta/FAQ per task — POST in inventory, so
//   defer the model too)
// IdempotencyKey is in Redis, not Postgres
