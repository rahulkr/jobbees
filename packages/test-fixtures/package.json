{
  "name": "@jobbees/test-fixtures",
  "version": "0.1.0",
  "description": "Named factory functions for test data. Use across api + admin + web test suites.",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./users": "./src/users.ts",
    "./jobs": "./src/jobs.ts",
    "./offers": "./src/offers.ts",
    "./payments": "./src/payments.ts",
    "./disputes": "./src/disputes.ts",
    "./reviews": "./src/reviews.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0",
    "@paralleldrive/cuid2": "^2.2.2"
  },
  "devDependencies": {
    "@jobbees/eslint-config": "workspace:*",
    "@jobbees/tsconfig": "workspace:*",
    "@types/node": "^22.20.0",
    "typescript": "5.9.3",
    "vitest": "^2.0.0"
  }
}
