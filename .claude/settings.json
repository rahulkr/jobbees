{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(pnpm exec:*)",
      "Bash(npx prisma:*)",
      "Bash(prisma:*)",
      "Bash(git:*)",
      "Bash(flutter:*)",
      "Bash(dart:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(turbo:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Edit",
      "Write",
      "Read",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
