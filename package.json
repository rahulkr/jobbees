{
  "name": "jobbees",
  "version": "0.1.0",
  "private": true,
  "description": "JOBBees — Australian peer-to-peer task marketplace monorepo",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @jobbees/prisma generate",
    "db:migrate:dev": "pnpm --filter @jobbees/prisma migrate:dev",
    "db:migrate:deploy": "pnpm --filter @jobbees/prisma migrate:deploy",
    "db:studio": "pnpm --filter @jobbees/prisma studio",
    "db:seed": "pnpm --filter @jobbees/prisma seed",
    "docker:up": "docker compose -f ops/docker/dev.yml up -d",
    "docker:down": "docker compose -f ops/docker/dev.yml down",
    "docker:logs": "docker compose -f ops/docker/dev.yml logs -f",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@jobbees/eslint-config": "workspace:*",
    "@jobbees/tsconfig": "workspace:*",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "eslint": "^9.18.0"
    },
    "comment": "Pinned to ESLint v9 because eslint-plugin-react (used by Next.js's eslint-config-next) calls the legacy context.getFilename() API, which ESLint v10 removed. Revisit when the React plugin and the wider ecosystem catch up. Until then, do NOT bump eslint past ^9 — it will break apps/admin and apps/web lint."
  }
}
