# --- Database ---
DATABASE_URL="postgresql://jobbees:jobbees@localhost:5432/jobbees?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="change-me-locally-only"
JWT_REFRESH_SECRET="change-me-locally-only"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL="30d"

# --- OTP provider (Sprint 1 default: mock — Sprint 5 swap to firebase) ---
# 'mock' = MockOtpService — accepts hardcoded code 000000 for any phone (dev/staging only)
# 'firebase' = Firebase Phone Auth (real SMS, production)
# Production app startup REFUSES to boot if OTP_PROVIDER=mock + NODE_ENV=production.
# Semgrep also blocks mock in any .env.production* or .env.staging* file.
OTP_PROVIDER="mock"
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# --- Stripe (test mode in dev) ---
STRIPE_SECRET_KEY="sk_test_..."
# From `stripe listen --forward-to localhost:3000/webhooks/stripe` in dev.
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_CONNECT_CLIENT_ID="ca_..."
# Where Connect onboarding returns to (mobile reopens the app + polls status).
STRIPE_CONNECT_RETURN_URL="http://localhost:3000/connect/return"

# --- LLM providers ---
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# --- Azure ---
AZURE_STORAGE_ACCOUNT=""
AZURE_STORAGE_KEY=""
AZURE_STORAGE_CONTAINER="jobbees-media"
AZURE_CONTENT_SAFETY_ENDPOINT=""
AZURE_CONTENT_SAFETY_KEY=""

# --- Notifications ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@jobbees.example"

# --- Push ---
FCM_SERVER_KEY=""
APNS_KEY_ID=""
APNS_TEAM_ID=""

# --- Observability ---
SENTRY_DSN=""
APPINSIGHTS_CONNECTION_STRING=""

# --- Geocoding ---
MAPBOX_TOKEN=""

# --- Feature flags ---
NODE_ENV="development"
APP_BASE_URL="http://localhost:3000"
ADMIN_BASE_URL="http://localhost:3001"
API_BASE_URL="http://localhost:3002"

# Auth — access JWT signing (min 32 chars). Generate: openssl rand -base64 48
JWT_ACCESS_SECRET="change-me-min-32-chars-xxxxxxxxxxxxxxxxxxxx"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# Social login audiences (comma-separated). Empty in dev → social login returns
# 503 until set. Google: OAuth 2.0 client IDs (Google Cloud Console). Apple:
# bundle id com.seaford.jobbees + any Services ID.
GOOGLE_OAUTH_CLIENT_IDS=
APPLE_CLIENT_IDS=

# ABR (Australian Business Register) lookup GUID — free registration at
# abr.business.gov.au. Empty in dev → ABN flow uses a stub (non-prod only).
ABR_GUID=
