  "info": {
    "title": "JOBBees API",
    "description": "JOBBees backend — auth foundation (Sprint 1)",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SignupDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jordan@example.com"
          },
          "password": {
            "type": "string",
            "example": "a-strong-passphrase",
            "minLength": 10,
            "maxLength": 200
          },
          "firstName": {
            "type": "string",
            "example": "Jordan"
          },
          "lastName": {
            "type": "string",
            "example": "Lee"
          },
          "role": {
            "type": "string",
            "enum": [
              "CLIENT",
              "TASKER"
            ],
            "default": "CLIENT"
          }
        },
        "required": [
          "email",
          "password",
          "firstName",
          "lastName"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jordan@example.com"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "The opaque refresh token issued at login."
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "ReauthDto": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string",
            "description": "Current password, to unlock sensitive actions."
          }
        },
        "required": [
          "password"
        ]
      },
      "OtpSendDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+61400000000"
          }
        },
        "required": [
          "phone"
        ]
      },
      "OtpVerifyDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+61400000000"
          },
          "code": {
            "type": "string",
            "example": "000000",
            "description": "Dev: any phone accepts 000000"
          }
        },
        "required": [
          "phone",
          "code"
        ]
      },
      "OAuthLoginDto": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "description": "Provider ID token obtained by the client SDK."
          },
          "role": {
            "type": "string",
            "enum": [
              "CLIENT",
              "TASKER"
            ],
            "default": "CLIENT",
            "description": "Role to assign on first-time signup."
          },
          "firstName": {
            "type": "string",
            "description": "Client-supplied name (Apple sends it only on first auth)."
          },
          "lastName": {
            "type": "string"
          }
        },
        "required": [
          "idToken"
        ]
      },
      "VerifyEmailDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "The token from the verification email."
          }
        },
        "required": [
          "token"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jordan@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "The token from the password-reset email."
          },
          "newPassword": {
            "type": "string",
            "minLength": 10,
            "maxLength": 200
          }
        },
        "required": [
          "token",
          "newPassword"
        ]
      },
      "SuspendUserDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "description": "Reason recorded on the user + in the audit log."
          }
        }
      }
    }
  }
}
